#!/bin/sh

# Capture staged .ts files before prettier modifies them
STAGED_TS=$(git diff --cached --name-only --diff-filter=d -- '*.ts')

npm run format:fix

# Re-stage only files that were already staged (so prettier's changes are included in the commit)
if [ -n "$STAGED_TS" ]; then
  echo "$STAGED_TS" | xargs -r git add
fi
