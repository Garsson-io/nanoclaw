#!/bin/sh

# Block pushes on main branch from the main checkout (not worktrees)
# Consistent with pre-commit: only blocks main branch, not feature branches
# Worktrees have git-dir != git-common-dir
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null)
GIT_COMMON_PATH=$(git rev-parse --git-common-dir 2>/dev/null)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ "$GIT_DIR_PATH" = "$GIT_COMMON_PATH" ] && [ "$CURRENT_BRANCH" = "main" ]; then
  echo "" >&2
  echo "Blocked: pushes on main from the main checkout are not allowed." >&2
  echo "Use a worktree for dev work (claude-wt or git worktree add)." >&2
  echo "" >&2
  exit 1
fi
